# Provide ONE of the following keys. The agent auto-detects which provider to use.
# Priority order: Gemini > Groq > OpenAI.

# Google Gemini (recommended — generous free tier, no card required)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (free tier, llama-3.3-70b-versatile)
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI (paid)
OPENAI_API_KEY=

# Optional: override the default model for the active provider.
# Defaults: Gemini -> gemini-2.5-flash-lite, Groq -> llama-3.3-70b-versatile, OpenAI -> gpt-4.1-mini
# MODEL=
